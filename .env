# ============================================
# CNC Spindle Monitor Environment Variables
# ============================================

# ClickHouse Configuration
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_DATABASE=cnc_monitor
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# MQTT Broker (EMQX) Configuration
MQTT_BROKER=tcp://emqx:1883
MQTT_CLIENT_ID=cnc_monitor_backend
MQTT_TOPIC_ALARM=cnc/alarm
MQTT_TOPIC_STATUS=cnc/status
MQTT_QOS=1

# UDP Server Configuration
UDP_PORT=5555
UDP_BUFFER_SIZE=8388608

# HTTP API Server
HTTP_PORT=8080
WEBSOCKET_PORT=8081
METRICS_PORT=9090

# Monitoring Thresholds
VIBRATION_WARNING=2.8
VIBRATION_ALARM=7.1
VIBRATION_ALARM_DURATION_SEC=10
RUL_WARNING_THRESHOLD=500
RUL_ALARM_THRESHOLD=200

# Machine Configuration
MACHINE_COUNT=40
SENSORS_VIBRATION=8
SENSORS_TEMPERATURE=4
SENSORS_DISPLACEMENT=2

# Simulator Configuration
SIMULATOR_UDP_TARGET=rust-backend:5555
SIMULATOR_MACHINE_COUNT=40
SIMULATOR_SAMPLE_INTERVAL_MS=100
SIMULATOR_ANOMALY_INJECT=true
SIMULATOR_DEGRADATION_INJECT=true

# Logging
RUST_LOG=info
RUST_BACKTRACE=0

# Timezone
TZ=Asia/Shanghai

# Prometheus Configuration
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_RETENTION=30d

# Grafana Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123
